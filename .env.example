# Coinbase CDP - Get from https://portal.cdp.coinbase.com/
# (Only needed for LIVE mode — paper trading doesn't use this)
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_API_KEY_PRIVATE_KEY=your_cdp_private_key

# Anthropic - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514
ANTHROPIC_REVIEW_MODEL=claude-3-5-haiku-latest

# Trading Config
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
RISK_PROFILE=moderate
TRADING_CAPITAL_USD=1000
ANALYSIS_INTERVAL_MS=300000

# Cost + call policy controls
FORCE_AI_CALL_MS=1800000
AI_TRIGGER_PRICE_MOVE_PCT=1.0
AI_TRIGGER_FNG_DELTA=5
AI_TRIGGER_SIGNAL_CHANGES=2

# Risk + execution guardrails
PER_TRADE_RISK_PCT=0.75
DAILY_MAX_DRAWDOWN_PCT=3
MIN_TRADE_USD=30
ESTIMATED_ROUND_TRIP_COST_BPS=80
MIN_NET_EDGE_BPS=25
MIN_CONFIDENCE_WITHOUT_EDGE=72

# Reliability controls
FAILSAFE_THRESHOLD=3
CLAUDE_MAX_RETRIES=2
CLAUDE_RETRY_DELAY_MS=5000
HISTORICAL_CACHE_TTL_MS=900000
REVIEW_INTERVAL_MINUTES=60

# Cost telemetry (used for business return tracking on dashboard)
COST_CLAUDE_ANALYSIS_USD=0.012
COST_CLAUDE_REVIEW_USD=0.015
COST_GROK_RESEARCH_USD=0.00012
COST_GROK_DERIVATIVES_USD=0.00012
FIXED_MONTHLY_INFRA_USD=0

# Proxy settings (Railway/ingress)
TRUST_PROXY_HOPS=1
LOG_AUTH_FAILURES=false

# Supabase — Shared Knowledge Layer (optional)
# Get from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Bot Instance ID — unique identifier for this bot instance
# Used to tag trades/reviews in the shared knowledge pool
BOT_INSTANCE_ID=primary
